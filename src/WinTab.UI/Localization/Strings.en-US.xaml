<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=System.Runtime">

    <!-- Application -->
    <system:String x:Key="App_Name">WinTab</system:String>
    <system:String x:Key="App_Description">Open-source window tab manager</system:String>
    <system:String x:Key="Shell_Tagline">Merge newly opened Explorer folders into tabs whenever possible to reduce window switching.</system:String>
    <system:String x:Key="Shell_StatusPrimary">Windows 10 / 11</system:String>
    <system:String x:Key="Shell_StatusSecondary">Light / Dark · Chinese / English</system:String>

    <!-- Navigation -->
    <system:String x:Key="Nav_General">General</system:String>
    <system:String x:Key="Nav_Behavior">Interaction</system:String>
    <system:String x:Key="Nav_Uninstall">Uninstall</system:String>
    <system:String x:Key="Nav_About">About</system:String>

    <!-- General Page -->
    <system:String x:Key="General_Title">Startup and appearance</system:String>
    <system:String x:Key="General_Lead">Configure how WinTab starts, stays available, and applies language and theme settings.</system:String>
    <system:String x:Key="General_Startup">Startup</system:String>
    <system:String x:Key="General_SectionStartup">Launch and availability</system:String>
    <system:String x:Key="General_SectionStartup_Desc">Control when WinTab starts, whether the main window is shown, and whether the tray entry remains available.</system:String>
    <system:String x:Key="General_SectionExperience">Appearance and language</system:String>
    <system:String x:Key="General_SectionExperience_Desc">Keep language and theme settings consistent with daily use.</system:String>
    <system:String x:Key="General_RunAtStartup">Run at Windows startup</system:String>
    <system:String x:Key="General_RunAtStartup_Desc">Start WinTab automatically after you sign in to Windows.</system:String>
    <system:String x:Key="General_StartMinimized">Start with the main window hidden</system:String>
    <system:String x:Key="General_StartMinimized_Desc">Do not show the main window on launch; requires the tray icon to remain enabled.</system:String>
    <system:String x:Key="General_ShowTrayIcon">Show tray icon</system:String>
    <system:String x:Key="General_ShowTrayIcon_Desc">Display the WinTab icon in the taskbar notification area.</system:String>
    <system:String x:Key="General_Language">Language</system:String>
    <system:String x:Key="General_LanguageLabel">Interface language</system:String>
    <system:String x:Key="General_LanguageLabel_Desc">Takes effect immediately without restarting the app.</system:String>
    <system:String x:Key="General_Chinese">Simplified Chinese</system:String>
    <system:String x:Key="General_English">English</system:String>

    <!-- Behavior Page -->
    <system:String x:Key="Behavior_Group_Interception">System integration</system:String>
    <system:String x:Key="Behavior_Group_Tabs">Tab rules</system:String>
    <system:String x:Key="Behavior_Title">Explorer interaction</system:String>
    <system:String x:Key="Behavior_Lead">Configure how WinTab captures Explorer windows and applies tab behavior. Enable items gradually based on your workflow.</system:String>
    <system:String x:Key="Behavior_SectionCapture">Window capture</system:String>
    <system:String x:Key="Behavior_SectionCapture_Desc">Control whether externally opened Explorer windows are merged into an existing WinTab window.</system:String>
    <system:String x:Key="Behavior_SectionTabs">Tab rules</system:String>
    <system:String x:Key="Behavior_SectionTabs_Desc">Choose where new tabs open and how tabs can be closed quickly.</system:String>
    <system:String x:Key="Behavior_RestartHint">Some capture settings apply fully only after WinTab restarts. If behavior does not change, close the app and open it again.</system:String>
    <system:String x:Key="Behavior_EnableExplorerOpenVerbInterception">Intercept external folder open requests</system:String>
    <system:String x:Key="Behavior_EnableExplorerOpenVerbInterception_Desc">Route folder open requests from Windows or other apps into a new tab in the current WinTab window.</system:String>
    <system:String x:Key="Behavior_EnableAutoConvertExplorerWindows">Intercept all Explorer windows</system:String>
    <system:String x:Key="Behavior_EnableAutoConvertExplorerWindows_Desc">Convert Explorer windows launched by third-party apps or command line into tabs; requires restart.</system:String>
    <system:String x:Key="Behavior_OpenNewTabFromActiveTabPath">Use the current path for new tabs</system:String>
    <system:String x:Key="Behavior_OpenNewTabFromActiveTabPath_Desc">Open new tabs in the active tab's folder instead of defaulting to This PC.</system:String>
    <system:String x:Key="Behavior_OpenChildFolderInNewTab">Open subfolders in new tabs</system:String>
    <system:String x:Key="Behavior_OpenChildFolderInNewTab_Desc">Open subfolders in a new tab while keeping the current view unchanged.</system:String>
    <system:String x:Key="Behavior_CloseTabOnDoubleClick">Double-click a tab title to close it</system:String>
    <system:String x:Key="Behavior_CloseTabOnDoubleClick_Desc">Double-click the tab title area to close that tab.</system:String>

    <!-- Appearance -->
    <system:String x:Key="Appearance_Theme">Theme</system:String>
    <system:String x:Key="Appearance_Theme_Desc">Choose a light or dark interface appearance.</system:String>
    <system:String x:Key="Appearance_ThemeLight">Light</system:String>
    <system:String x:Key="Appearance_ThemeDark">Dark</system:String>

    <!-- About Page -->
    <system:String x:Key="About_Title">About WinTab</system:String>
    <system:String x:Key="About_Lead">WinTab is an open-source tool for tab-oriented Explorer management, designed to reduce window switching without forcing a new workflow.</system:String>
    <system:String x:Key="About_Version">Version</system:String>
    <system:String x:Key="About_Description">An open-source tab utility for Windows Explorer that keeps file browsing organized in fewer windows.</system:String>
    <system:String x:Key="About_License">License: MIT</system:String>
    <system:String x:Key="About_GitHub">GitHub</system:String>
    <system:String x:Key="About_GitHub_Desc">Review source code, release history, and public issue tracking.</system:String>
    <system:String x:Key="About_SectionProject">Project</system:String>
    <system:String x:Key="About_SectionProject_Desc">See where this build comes from and where future updates are published.</system:String>
    <system:String x:Key="About_SectionDiagnostics">Diagnostics and logs</system:String>
    <system:String x:Key="About_SectionDiagnostics_Desc">Check the log first when capture, navigation, or flicker behavior looks wrong.</system:String>
    <system:String x:Key="About_ModeInstalled">Installed build</system:String>
    <system:String x:Key="About_ModePortable">Portable build</system:String>
    <system:String x:Key="About_LogLocation">Log file location</system:String>
    <system:String x:Key="About_OpenLog">Open log</system:String>
    <system:String x:Key="About_OpenLogFolder">Open log folder</system:String>

    <!-- Uninstall Page -->
    <system:String x:Key="Uninstall_Title">Uninstall WinTab</system:String>
    <system:String x:Key="Uninstall_Lead">Uninstall WinTab, decide whether to remove local data, or restore only the system configuration written by WinTab.</system:String>
    <system:String x:Key="Uninstall_SectionRemoval">Removal and cleanup</system:String>
    <system:String x:Key="Uninstall_SectionRemoval_Desc">This is the main uninstall path. By default only program files are removed; delete local configuration and logs only when full cleanup is required.</system:String>
    <system:String x:Key="Uninstall_SectionMaintenance">System restore and manual handling</system:String>
    <system:String x:Key="Uninstall_SectionMaintenance_Desc">If you are not uninstalling yet, you can restore WinTab system changes or open the app directory and logs for manual inspection.</system:String>
    <system:String x:Key="Uninstall_DefaultBehavior">By default only app files are removed. Enable Remove user data to also delete settings and logs.</system:String>
    <system:String x:Key="Uninstall_ModeLabel">Run mode</system:String>
    <system:String x:Key="Uninstall_ModeInstalled">Installed</system:String>
    <system:String x:Key="Uninstall_ModePortable">Portable</system:String>
    <system:String x:Key="Uninstall_PathLabel">Uninstaller</system:String>
    <system:String x:Key="Uninstall_PathMissing">Uninstaller not found. Use Open system uninstall settings instead.</system:String>
    <system:String x:Key="Uninstall_Button">Uninstall WinTab</system:String>
    <system:String x:Key="Uninstall_OpenSystem">Open system uninstall settings</system:String>
    <system:String x:Key="Uninstall_OpenFolder">Open app directory</system:String>
    <system:String x:Key="Uninstall_OpenLog">Open log</system:String>
    <system:String x:Key="Uninstall_RemoveUserData">Remove user data</system:String>
    <system:String x:Key="Uninstall_RemoveUserData_Desc">Disabled by default. Use only for full cleanup; this deletes AppData\Roaming\WinTab.</system:String>
    <system:String x:Key="Uninstall_ConfirmTitle">Confirm uninstall</system:String>
    <system:String x:Key="Uninstall_Confirm">WinTab uninstaller will be started. Continue?</system:String>
    <system:String x:Key="Uninstall_LaunchFailed">Unable to start the uninstaller. Use system uninstall settings instead.</system:String>
    <system:String x:Key="Uninstall_PortableHint">Portable mode detected. Close WinTab and delete the app directory to uninstall.</system:String>
    <system:String x:Key="Uninstall_RestoreSystemConfig">Restore system configuration</system:String>
    <system:String x:Key="Uninstall_RestoreSystemConfig_Desc">Remove system changes written by WinTab, including startup registration, Explorer interception, and the HKCU\Software\WinTab registry tree.</system:String>
    <system:String x:Key="Uninstall_RestoreSystemConfig_Confirm">This will remove WinTab system changes, including startup registration, Explorer interception, and WinTab registry entries. Continue?</system:String>
    <system:String x:Key="Uninstall_RestoreSystemConfig_Success">System configuration restored.</system:String>
    <system:String x:Key="Uninstall_RestoreSystemConfig_Partial">Some restore operations failed. Check the log for details.</system:String>

    <!-- Tray Icon -->
    <system:String x:Key="Tray_Open">Show main window</system:String>
    <system:String x:Key="Tray_Exit">Exit app</system:String>
    <system:String x:Key="Tray_Tooltip">WinTab - Window Tab Manager</system:String>

    <!-- Common -->
    <system:String x:Key="Common_Save">Save</system:String>
    <system:String x:Key="Common_Cancel">Cancel</system:String>
    <system:String x:Key="Common_Close">Close</system:String>
    <system:String x:Key="Common_Apply">Apply</system:String>
    <system:String x:Key="Common_OK">OK</system:String>
    <system:String x:Key="Common_Yes">Yes</system:String>
    <system:String x:Key="Common_No">No</system:String>
    <system:String x:Key="Common_Enabled">Enabled</system:String>
    <system:String x:Key="Common_Disabled">Disabled</system:String>

</ResourceDictionary>
