<Page x:Class="WinTab.App.Views.Pages.UninstallPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:WinTab.App.ViewModels"
      d:DataContext="{d:DesignInstance vm:UninstallViewModel}"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="UninstallPage">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/WinTab.UI;component/Themes/DesignPrimitives.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      CanContentScroll="False"
                      PanningMode="VerticalFirst"
                      Padding="28,28,28,36">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="760"
                        Grid.IsSharedSizeScope="True">

                <Border Style="{StaticResource AppDangerPanelBorderStyle}"
                        Margin="0,0,0,24">
                    <StackPanel>
                        <ui:SymbolIcon Symbol="Delete24"
                                       FontSize="40"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,14"/>
                        <TextBlock Text="{DynamicResource Nav_Uninstall}"
                                   Style="{StaticResource PageEyebrowStyle}" />
                        <TextBlock Text="{DynamicResource Uninstall_Title}"
                                   Style="{StaticResource PageHeaderTitleStyle}" />
                        <TextBlock Text="{DynamicResource Uninstall_Lead}"
                                   Style="{StaticResource PageHeaderDescriptionStyle}" />
                    </StackPanel>
                </Border>

                <TextBlock Text="{DynamicResource Uninstall_SectionRemoval}"
                           Style="{StaticResource PageSectionTitleStyle}" />
                <TextBlock Text="{DynamicResource Uninstall_SectionRemoval_Desc}"
                           Style="{StaticResource SectionDescriptionStyle}" />

                <Border Style="{StaticResource SettingRowBorderStyle}"
                        Margin="0,0,0,20">
                    <StackPanel Margin="4">
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Text="{DynamicResource Uninstall_ModeLabel}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Grid.Row="0" Grid.Column="0" Margin="0,0,24,16" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ModeText}" Grid.Row="0" Grid.Column="1" Margin="0,0,0,16" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" TextWrapping="Wrap"/>
                            
                            <!-- Uninstaller path row: installed mode only -->
                            <TextBlock Text="{DynamicResource Uninstall_PathLabel}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Grid.Row="1" Grid.Column="0" Margin="0,0,24,0" VerticalAlignment="Top"
                                       Visibility="{Binding IsInstalled, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <TextBlock Text="{Binding UninstallerPathText}" Grid.Row="1" Grid.Column="1" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Top" LineHeight="20"
                                       Visibility="{Binding IsInstalled, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </Grid>

                        <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" Margin="0,8,0,20"/>

                        <StackPanel Margin="0,0,0,28"
                                    Visibility="{Binding IsInstalled, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <CheckBox Content="{DynamicResource Uninstall_RemoveUserData}"
                                      IsChecked="{Binding RemoveUserDataOnUninstall, Mode=TwoWay}"
                                      IsEnabled="{Binding IsRemoveUserDataOptionEnabled}" 
                                      FontSize="14" FontWeight="Medium" />
                            <TextBlock Text="{DynamicResource Uninstall_RemoveUserData_Desc}"
                                       Margin="32,8,0,0" LineHeight="20"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" FontSize="13" />
                        </StackPanel>

                        <TextBlock Text="{DynamicResource Uninstall_RestoreSystemConfig_Desc}"
                                   Margin="0,0,0,28" LineHeight="20"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap" FontSize="13"
                                   Visibility="{Binding IsPortable, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                    Visibility="{Binding IsInstalled, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ui:Button Content="{DynamicResource Uninstall_Button}"
                                       Icon="{ui:SymbolIcon Delete24}"
                                       Appearance="Secondary"
                                       Padding="24,10"
                                       Margin="0,0,12,12"
                                       Command="{Binding StartUninstallCommand}" />
                            <ui:Button Content="{DynamicResource Uninstall_OpenSystem}"
                                       Icon="{ui:SymbolIcon WindowWrench24}"
                                       Padding="16,10"
                                       Command="{Binding OpenSystemUninstallCommand}"
                                       Margin="0,0,12,12" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <TextBlock Text="{DynamicResource Uninstall_SectionMaintenance}"
                           Style="{StaticResource PageSectionTitleStyle}" />
                <TextBlock Text="{DynamicResource Uninstall_SectionMaintenance_Desc}"
                           Style="{StaticResource SectionDescriptionStyle}" />

                <Border Style="{StaticResource SettingRowBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" SharedSizeGroup="SettingActionColumn" />
                        </Grid.ColumnDefinitions>

                        <StackPanel MaxWidth="420">
                            <TextBlock Text="{DynamicResource Uninstall_RestoreSystemConfig}"
                                       Style="{StaticResource SettingTitleStyle}" />
                            <TextBlock Text="{DynamicResource Uninstall_RestoreSystemConfig_Desc}"
                                       Style="{StaticResource SettingDescriptionStyle}"
                                       Margin="0,2,0,0" />
                        </StackPanel>

                        <Border Grid.Column="1" Style="{StaticResource SettingRowActionHostStyle}">
                            <WrapPanel Orientation="Horizontal"
                                       HorizontalAlignment="Right">
                                <ui:Button Content="{DynamicResource Uninstall_RestoreSystemConfig}"
                                           Icon="{ui:SymbolIcon ArrowCounterclockwise24}"
                                           Appearance="Secondary"
                                           Padding="24,10"
                                           Margin="0,0,12,12"
                                           Command="{Binding RestoreSystemConfigCommand}" />
                                <ui:Button Content="{DynamicResource Uninstall_OpenFolder}"
                                           Icon="{ui:SymbolIcon Folder24}"
                                           Padding="16,10"
                                           Command="{Binding OpenAppDirectoryCommand}"
                                           Margin="0,0,0,12" />
                            </WrapPanel>
                        </Border>
                    </Grid>
                </Border>

                <TextBlock Text="{DynamicResource Uninstall_PortableHint}"
                           HorizontalAlignment="Center" TextAlignment="Center" LineHeight="20"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           FontSize="13" TextWrapping="Wrap" MaxWidth="540"
                           Margin="0,18,0,0"
                           Visibility="{Binding IsPortable, Converter={StaticResource BooleanToVisibilityConverter}}"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
