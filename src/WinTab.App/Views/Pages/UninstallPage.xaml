<Page x:Class="WinTab.App.Views.Pages.UninstallPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:WinTab.App.ViewModels"
      d:DataContext="{d:DesignInstance vm:UninstallViewModel}"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="UninstallPage">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Page.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="680" Margin="24,52,24,28">
                
                <ui:SymbolIcon Symbol="Delete24" FontSize="48" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,18"/>
                <TextBlock Text="{DynamicResource Uninstall_Title}"
                           FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"
                           Margin="0,0,0,30" />

                <ui:CardControl Margin="0,0,0,24">
                    <StackPanel Margin="16">
                        <!-- Environment Info -->
                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Text="{DynamicResource Uninstall_ModeLabel}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Grid.Row="0" Grid.Column="0" Margin="0,0,24,16" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ModeText}" Grid.Row="0" Grid.Column="1" Margin="0,0,0,16" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" TextWrapping="Wrap"/>
                            
                            <!-- Uninstaller path row: installed mode only -->
                            <TextBlock Text="{DynamicResource Uninstall_PathLabel}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Grid.Row="1" Grid.Column="0" Margin="0,0,24,0" VerticalAlignment="Top"
                                       Visibility="{Binding IsInstalled, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <TextBlock Text="{Binding UninstallerPathText}" Grid.Row="1" Grid.Column="1" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Top" LineHeight="20"
                                       Visibility="{Binding IsInstalled, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </Grid>

                        <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" Margin="0,8,0,24"/>

                        <!-- Installed mode: Remove user data option -->
                        <StackPanel Margin="0,0,0,28"
                                    Visibility="{Binding IsInstalled, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <CheckBox Content="{DynamicResource Uninstall_RemoveUserData}"
                                      IsChecked="{Binding RemoveUserDataOnUninstall, Mode=TwoWay}"
                                      IsEnabled="{Binding IsRemoveUserDataOptionEnabled}" 
                                      FontSize="14" FontWeight="Medium" />
                            <TextBlock Text="{DynamicResource Uninstall_RemoveUserData_Desc}"
                                       Margin="32,8,0,0" LineHeight="20"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" FontSize="13" />
                        </StackPanel>

                        <!-- Portable mode: system config restore hint -->
                        <TextBlock Text="{DynamicResource Uninstall_RestoreSystemConfig_Desc}"
                                   Margin="0,0,0,28" LineHeight="20"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap" FontSize="13"
                                   Visibility="{Binding IsPortable, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <!-- Actions: installed mode -->
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                    Visibility="{Binding IsInstalled, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ui:Button Content="{DynamicResource Uninstall_Button}"
                                       Icon="{ui:SymbolIcon Delete24}"
                                       Appearance="Secondary"
                                       Padding="24,10"
                                       Margin="0,0,12,12"
                                       Command="{Binding StartUninstallCommand}" />
                            <ui:Button Content="{DynamicResource Uninstall_OpenSystem}"
                                       Icon="{ui:SymbolIcon WindowWrench24}"
                                       Padding="16,10"
                                       Command="{Binding OpenSystemUninstallCommand}"
                                       Margin="0,0,12,12" />
                            <ui:Button Content="{DynamicResource Uninstall_OpenFolder}"
                                       Icon="{ui:SymbolIcon Folder24}"
                                       Padding="16,10"
                                       Command="{Binding OpenAppDirectoryCommand}"
                                       Margin="0,0,0,12" />
                        </WrapPanel>

                        <!-- Actions: portable mode -->
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                    Visibility="{Binding IsPortable, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ui:Button Content="{DynamicResource Uninstall_RestoreSystemConfig}"
                                       Icon="{ui:SymbolIcon ArrowCounterclockwise24}"
                                       Appearance="Secondary"
                                       Padding="24,10"
                                       Margin="0,0,12,12"
                                       Command="{Binding RestoreSystemConfigCommand}" />
                            <ui:Button Content="{DynamicResource Uninstall_OpenFolder}"
                                       Icon="{ui:SymbolIcon Folder24}"
                                       Padding="16,10"
                                       Command="{Binding OpenAppDirectoryCommand}"
                                       Margin="0,0,0,12" />
                        </WrapPanel>
                    </StackPanel>
                </ui:CardControl>

                <!-- Bottom hint: portable mode -->
                <TextBlock Text="{DynamicResource Uninstall_PortableHint}"
                           HorizontalAlignment="Center" TextAlignment="Center" LineHeight="20"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           FontSize="13" TextWrapping="Wrap" MaxWidth="540"
                           Visibility="{Binding IsPortable, Converter={StaticResource BooleanToVisibilityConverter}}"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
