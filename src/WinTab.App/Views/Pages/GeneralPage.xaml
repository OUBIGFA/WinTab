<Page x:Class="WinTab.App.Views.Pages.GeneralPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:WinTab.App.ViewModels"
      d:DataContext="{d:DesignInstance vm:GeneralViewModel}"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="GeneralPage">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/WinTab.UI;component/Themes/DesignPrimitives.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,28,28,36">
        <StackPanel Margin="0,0,24,0" MaxWidth="880">

            <Border Style="{StaticResource AppPanelBorderStyle}"
                    Background="{DynamicResource AppSurfaceStrongBrush}"
                    Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Nav_General}"
                               Style="{StaticResource PageEyebrowStyle}" />
                    <TextBlock Text="{DynamicResource General_Title}"
                               Style="{StaticResource PageHeaderTitleStyle}" />
                    <TextBlock Text="{DynamicResource General_Lead}"
                               Style="{StaticResource PageHeaderDescriptionStyle}" />
                </StackPanel>
            </Border>

            <TextBlock Text="{DynamicResource General_SectionStartup}"
                       Style="{StaticResource PageSectionTitleStyle}" />
            <TextBlock Text="{DynamicResource General_SectionStartup_Desc}"
                       Style="{StaticResource SectionDescriptionStyle}" />

            <ui:CardControl Style="{StaticResource SettingsCardStyle}">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="{DynamicResource General_RunAtStartup}" Style="{StaticResource SettingTitleStyle}" />
                        <TextBlock Text="{DynamicResource General_RunAtStartup_Desc}"
                                   Style="{StaticResource SettingDescriptionStyle}" />
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:ToggleSwitch IsChecked="{Binding RunAtStartup, Mode=TwoWay}" />
            </ui:CardControl>

            <ui:CardControl Style="{StaticResource SettingsCardStyle}">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="{DynamicResource General_StartMinimized}" Style="{StaticResource SettingTitleStyle}" />
                        <TextBlock Text="{DynamicResource General_StartMinimized_Desc}"
                                   Style="{StaticResource SettingDescriptionStyle}" />
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:ToggleSwitch IsChecked="{Binding StartMinimized, Mode=TwoWay}" />
            </ui:CardControl>

            <ui:CardControl Style="{StaticResource SettingsCardStyle}"
                            Margin="0,0,0,24">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="{DynamicResource General_ShowTrayIcon}" Style="{StaticResource SettingTitleStyle}" />
                        <TextBlock Text="{DynamicResource General_ShowTrayIcon_Desc}"
                                   Style="{StaticResource SettingDescriptionStyle}" />
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:ToggleSwitch IsChecked="{Binding ShowTrayIcon, Mode=TwoWay}" />
            </ui:CardControl>

            <TextBlock Text="{DynamicResource General_SectionExperience}"
                       Style="{StaticResource PageSectionTitleStyle}" />
            <TextBlock Text="{DynamicResource General_SectionExperience_Desc}"
                       Style="{StaticResource SectionDescriptionStyle}" />

            <ui:CardControl Style="{StaticResource SettingsCardStyle}">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="{DynamicResource General_LanguageLabel}" Style="{StaticResource SettingTitleStyle}" />
                        <TextBlock Text="{DynamicResource General_LanguageLabel_Desc}"
                                   Style="{StaticResource SettingDescriptionStyle}" />
                    </StackPanel>
                </ui:CardControl.Header>
                <ComboBox SelectedIndex="{Binding SelectedLanguageIndex, Mode=TwoWay}"
                          MinWidth="160">
                    <ComboBoxItem Content="{DynamicResource General_Chinese}" />
                    <ComboBoxItem Content="{DynamicResource General_English}" />
                </ComboBox>
            </ui:CardControl>

            <ui:CardControl Style="{StaticResource SettingsCardStyle}"
                            Margin="0,0,0,8">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Appearance_Theme}" Style="{StaticResource SettingTitleStyle}" />
                        <TextBlock Text="{DynamicResource Appearance_Theme_Desc}"
                                   Style="{StaticResource SettingDescriptionStyle}" />
                    </StackPanel>
                </ui:CardControl.Header>
                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="{DynamicResource Appearance_ThemeLight}"
                                 IsChecked="{Binding IsThemeLight, Mode=TwoWay}"
                                 GroupName="Theme"
                                 MinWidth="96" />
                    <RadioButton Content="{DynamicResource Appearance_ThemeDark}"
                                 IsChecked="{Binding IsThemeDark, Mode=TwoWay}"
                                 GroupName="Theme"
                                 MinWidth="96"
                                 Margin="16,0,0,0" />
                </StackPanel>
            </ui:CardControl>

        </StackPanel>
    </ScrollViewer>
</Page>
