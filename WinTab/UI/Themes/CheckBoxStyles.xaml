<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Switch-style CheckBox used by the settings panel. -->
    <Style x:Key="CustomCheckBoxStyle" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid Background="Transparent" MinWidth="48" MinHeight="28">
                        <Border x:Name="SwitchTrack"
                                Width="48"
                                Height="26"
                                HorizontalAlignment="Right"
                                Background="{DynamicResource ControlHoverBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="13">
                            <Grid>
                                <Ellipse x:Name="SwitchThumb"
                                         Width="20"
                                         Height="20"
                                         Margin="3,0,0,0"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Fill="{DynamicResource DropdownBackgroundBrush}" />
                                <Path x:Name="CheckMark"
                                      Data="M5.2,9.3 L8.2,12.2 L14.8,5.8"
                                      Stroke="{DynamicResource CheckBoxCheckedGlyphBrush}"
                                      StrokeThickness="1.8"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Stretch="Uniform"
                                      Width="10"
                                      Height="8"
                                      HorizontalAlignment="Right"
                                      Margin="0,0,9,0"
                                      Visibility="Collapsed" />
                            </Grid>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.7" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="SwitchTrack" Property="Background" Value="{DynamicResource AccentBrush}" />
                            <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="{DynamicResource CheckBoxCheckedBorderBrush}" />
                            <Setter TargetName="SwitchThumb" Property="HorizontalAlignment" Value="Right" />
                            <Setter TargetName="SwitchThumb" Property="Margin" Value="0,0,3,0" />
                            <Setter TargetName="SwitchThumb" Property="Fill" Value="{DynamicResource CheckBoxCheckedGlyphBrush}" />
                            <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="{DynamicResource PrimaryLightBrush}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="{DynamicResource PrimaryLightBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
