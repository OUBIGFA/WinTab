<Window x:Class="WinTab.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinTab"
        Width="1020"
        Height="720"
        MinWidth="880"
        MinHeight="560"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        TextElement.Foreground="{DynamicResource TextPrimaryBrush}">

    <Window.Resources>
        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Padding" Value="24" />
        </Style>

        <Style x:Key="SoftPanelStyle" TargetType="Border" BasedOn="{StaticResource PanelBorderStyle}">
            <Setter Property="Background" Value="{DynamicResource SurfaceMutedBrush}" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16.5" />
            <Setter Property="FontWeight" Value="Medium" />
        </Style>

        <Style x:Key="SectionDescriptionStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="LineHeight" Value="20" />
        </Style>

        <Style x:Key="SettingTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Medium" />
        </Style>

        <Style x:Key="SettingDescriptionStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="LineHeight" Value="20" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>

        <Style x:Key="SettingRowStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="0,0,0,17" />
            <Setter Property="Margin" Value="0,0,0,17" />
        </Style>

        <Style x:Key="TinyMetaStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextTertiaryBrush}" />
            <Setter Property="FontSize" Value="12.8" />
            <Setter Property="LineHeight" Value="19" />
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource WindowBackgroundBrush}"
            BorderBrush="{DynamicResource WindowBorderBrush}"
            BorderThickness="1"
            CornerRadius="12">
        <Grid ClipToBounds="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="50" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border x:Name="TitleBar"
                    Grid.Row="0"
                    Background="{DynamicResource WindowTitleBarBrush}"
                    CornerRadius="12,12,0,0"
                    BorderBrush="{DynamicResource DividerBrush}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="22,0,0,0">
                        <TextBlock x:Name="AppNameText" Text="WinTab" FontSize="15" FontWeight="Medium" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,14,0" VerticalAlignment="Center">
                        <Button x:Name="ThemeToggleButton"
                                Style="{StaticResource IconButtonStyle}"
                                Width="30"
                                Height="30"
                                Margin="0,0,4,0"
                                Focusable="False">
                            <Viewbox Width="15" Height="15" Stretch="Uniform">
                                <Path x:Name="ThemeToggleIconPath"
                                      Fill="{DynamicResource TextPrimaryBrush}"
                                      Data="M10 7C10 10.866 13.134 14 17 14C18.9584 14 20.729 13.1957 21.9995 11.8995C22 11.933 22 11.9665 22 12C22 17.5228 17.5228 22 12 22C6.47715 22 2 17.5228 2 12C2 6.47715 6.47715 2 12 2C12.0335 2 12.067 2 12.1005 2.00049C10.8043 3.27098 10 5.04157 10 7ZM4 12C4 16.4183 7.58172 20 12 20C15.0583 20 17.7158 18.2839 19.062 15.7621C18.3945 15.9187 17.7035 16 17 16C12.0294 16 8 11.9706 8 7C8 6.29648 8.08133 5.60547 8.2379 4.938C5.71611 6.28423 4 8.9417 4 12Z" />
                            </Viewbox>
                        </Button>
                        <Button x:Name="LanguageToggleButton"
                                Style="{StaticResource IconButtonStyle}"
                                Width="30"
                                Height="30"
                                Margin="0,0,8,0"
                                Focusable="False">
                            <Viewbox Width="15" Height="15" Stretch="Uniform">
                                <Path Fill="{DynamicResource TextPrimaryBrush}"
                                      Data="M5 15V17C5 18.0544 5.81588 18.9182 6.85074 18.9945L7 19H10V21H7C4.79086 21 3 19.2091 3 17V15H5ZM18 10L22.4 21H20.245L19.044 18H14.954L13.755 21H11.601L16 10H18ZM17 12.8852L15.753 16H18.245L17 12.8852ZM8 2V4H12V11H8V14H6V11H2V4H6V2H8ZM17 3C19.2091 3 21 4.79086 21 7V9H19V7C19 5.89543 18.1046 5 17 5H14V3H17ZM6 6H4V9H6V6ZM10 6H8V9H10V6Z" />
                            </Viewbox>
                        </Button>
                        <Button x:Name="MinimizeButton" Style="{StaticResource IconButtonStyle}" Content="&#x2212;" Focusable="False" />
                        <Button x:Name="CloseButton" Style="{StaticResource IconButtonStyle}" Content="&#x2715;" Focusable="False" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="286" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource SoftPanelStyle}"
                        Padding="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <Image Source="/WinTab;component/wintab-logo.png"
                                   Width="56"
                                   Height="56"
                                   HorizontalAlignment="Left"
                                   Stretch="Uniform" />

                            <TextBlock x:Name="HeroTitleText"
                                       Text="WinTab"
                                       Margin="0,20,0,0"
                                       FontSize="23"
                                       FontWeight="Medium"
                                       LineHeight="28"
                                       TextWrapping="Wrap" />
                            <TextBlock x:Name="HeroDescriptionText"
                                       Text="Keep File Explorer windows in one tab set."
                                       Margin="0,10,0,0"
                                       FontSize="13.5"
                                       LineHeight="21"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" />

                            <Border Margin="0,22,0,0"
                                    Padding="0,14,0,0"
                                    BorderBrush="{DynamicResource DividerBrush}"
                                    BorderThickness="0,1,0,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Background="{DynamicResource StatusPillBackgroundBrush}"
                                                BorderBrush="{DynamicResource StatusPillBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="5"
                                                Padding="8,3">
                                            <TextBlock x:Name="StatusPillText"
                                                       Text="Running"
                                                       FontSize="12.5"
                                                       FontWeight="Medium"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Margin="0,10,0,0">
                                        <TextBlock x:Name="StatusTrayText"
                                                   Text="Tray access is enabled"
                                                   Style="{StaticResource TinyMetaStyle}" />
                                        <TextBlock x:Name="StatusBypassText"
                                                   Text="Ctrl + Shift opens a separate Explorer window"
                                                   Margin="0,6,0,0"
                                                   Style="{StaticResource TinyMetaStyle}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="2">
                            <TextBlock x:Name="OpenSourceLicenseText"
                                       Text="MIT License"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                            <TextBlock x:Name="OpenSourceVersionText"
                                       Margin="0,6,0,0"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                            <TextBlock Margin="0,8,0,0"
                                       FontSize="12"
                                       TextWrapping="Wrap">
                                <Hyperlink x:Name="OpenSourceLink"
                                           NavigateUri="https://github.com/OUBIGFA/WinTab"
                                           RequestNavigate="OpenSourceLink_RequestNavigate">
                                    <Run x:Name="OpenSourceLinkText" Text="GitHub" />
                                </Hyperlink>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Column="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="True">
                    <StackPanel>
                        <Border Background="{DynamicResource SurfaceRaisedBrush}"
                                BorderBrush="{DynamicResource DividerBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="24,22">
                            <StackPanel>
                                <Border Style="{StaticResource SettingRowStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock x:Name="WindowHookTitleText" Text="Merge new windows" Style="{StaticResource SettingTitleStyle}" />
                                            <TextBlock x:Name="WindowHookDescText" Text="Send new folders back to the active Explorer tab group." Style="{StaticResource SettingDescriptionStyle}" />
                                        </StackPanel>
                                        <CheckBox x:Name="WindowHookToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource CustomCheckBoxStyle}"
                                                  VerticalAlignment="Center"
                                                  Margin="22,0,0,0" />
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource SettingRowStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock x:Name="ReuseTabsTitleText" Text="Reuse existing tabs" Style="{StaticResource SettingTitleStyle}" />
                                            <TextBlock x:Name="ReuseTabsDescText" Text="Open a matching path by focusing its current tab." Style="{StaticResource SettingDescriptionStyle}" />
                                        </StackPanel>
                                        <CheckBox x:Name="ReuseTabsToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource CustomCheckBoxStyle}"
                                                  VerticalAlignment="Center"
                                                  Margin="22,0,0,0" />
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource SettingRowStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock x:Name="DoubleClickTitleText" Text="Double-click closes tab" Style="{StaticResource SettingTitleStyle}" />
                                            <TextBlock x:Name="DoubleClickDescText" Text="Close the current Explorer tab from its title area." Style="{StaticResource SettingDescriptionStyle}" />
                                        </StackPanel>
                                        <CheckBox x:Name="DoubleClickCloseToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource CustomCheckBoxStyle}"
                                                  VerticalAlignment="Center"
                                                  Margin="22,0,0,0" />
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource SettingRowStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock x:Name="StartupTitleText" Text="Start with Windows" Style="{StaticResource SettingTitleStyle}" />
                                            <TextBlock x:Name="StartupDescText" Text="Run quietly after sign-in." Style="{StaticResource SettingDescriptionStyle}" />
                                        </StackPanel>
                                        <CheckBox x:Name="StartupToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource CustomCheckBoxStyle}"
                                                  VerticalAlignment="Center"
                                                  Margin="22,0,0,0" />
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource SettingRowStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock x:Name="ShowTrayIconTitleText" Text="Show tray icon" Style="{StaticResource SettingTitleStyle}" />
                                            <TextBlock x:Name="ShowTrayIconDescText" Text="Keep WinTab available from the notification area." Style="{StaticResource SettingDescriptionStyle}" />
                                        </StackPanel>
                                        <CheckBox x:Name="ShowTrayIconToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource CustomCheckBoxStyle}"
                                                  VerticalAlignment="Center"
                                                  Margin="22,0,0,0" />
                                    </Grid>
                                </Border>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock x:Name="AutoUpdateTitleText" Text="Check for updates" Style="{StaticResource SettingTitleStyle}" />
                                        <TextBlock x:Name="AutoUpdateDescText" Text="Notify when a GitHub release is available." Style="{StaticResource SettingDescriptionStyle}" />
                                    </StackPanel>
                                    <CheckBox x:Name="AutoUpdateToggle"
                                              Grid.Column="1"
                                              Style="{StaticResource CustomCheckBoxStyle}"
                                              VerticalAlignment="Center"
                                              Margin="22,0,0,0" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SoftPanelStyle}" Margin="0,14,0,0" Padding="24,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock x:Name="ActionsTitleText" Text="Maintenance" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock x:Name="ActionsDescText"
                                               Text="The app stays in the tray when this window closes."
                                               Style="{StaticResource SectionDescriptionStyle}"
                                               Margin="0,6,0,0" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="24,0,0,0">
                                    <Button x:Name="CheckUpdatesButton"
                                            Content="Check"
                                            Style="{StaticResource FlatButtonStyle}"
                                            MinWidth="84"
                                            Margin="0,0,8,0" />
                                    <Button x:Name="HideWindowButton"
                                            Content="Hide"
                                            Style="{StaticResource FlatButtonStyle}"
                                            MinWidth="84" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <Thumb x:Name="CornerResizeThumb"
                   Grid.RowSpan="2"
                   Width="18"
                   Height="18"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Bottom"
                   Margin="0,0,5,5"
                   Cursor="SizeNWSE"
                   Opacity="0.7"
                   ToolTip="Resize">
                <Thumb.Template>
                    <ControlTemplate TargetType="Thumb">
                        <Grid Background="Transparent">
                            <Path Stroke="{DynamicResource TextTertiaryBrush}"
                                  StrokeThickness="1.2"
                                  Data="M7,15 L15,7 M11,15 L15,11 M3,15 L15,3" />
                        </Grid>
                    </ControlTemplate>
                </Thumb.Template>
            </Thumb>
        </Grid>
    </Border>
</Window>
