<Window x:Class="WinTab.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinTab"
        Width="1080"
        Height="700"
        MinWidth="940"
        MinHeight="620"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        TextElement.Foreground="{DynamicResource TextPrimaryBrush}">

    <Window.Resources>
        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="24" />
        </Style>

        <Style x:Key="SoftPanelStyle" TargetType="Border" BasedOn="{StaticResource PanelBorderStyle}">
            <Setter Property="Background" Value="{DynamicResource CardGradientBrush}" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="SectionDescriptionStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="LineHeight" Value="21" />
        </Style>

        <Style x:Key="SettingTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="SettingDescriptionStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="LineHeight" Value="19" />
            <Setter Property="Margin" Value="0,5,0,0" />
        </Style>

        <Style x:Key="SettingRowStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="0,0,0,17" />
            <Setter Property="Margin" Value="0,0,0,17" />
        </Style>

        <Style x:Key="TinyMetaStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextTertiaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="LineHeight" Value="18" />
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource BackgroundGradientBrush}"
            BorderBrush="{DynamicResource BorderGradientBrush}"
            BorderThickness="1"
            CornerRadius="16">
        <Grid ClipToBounds="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="58" />
                <RowDefinition Height="*" />
                <RowDefinition Height="52" />
            </Grid.RowDefinitions>

            <Canvas Grid.RowSpan="3"
                    IsHitTestVisible="False"
                    Opacity="0.14">
                <Path Stroke="{DynamicResource BorderBrush}"
                      StrokeThickness="1"
                      Data="M-30,155 C90,118 146,218 282,176 C394,142 454,62 590,96 C744,135 804,252 984,210 C1092,185 1160,116 1260,142" />
                <Path Stroke="{DynamicResource BorderBrush}"
                      StrokeThickness="1"
                      Data="M-40,246 C96,212 176,318 306,268 C448,214 522,132 662,174 C812,218 900,330 1068,278 C1160,250 1215,214 1260,226" />
                <Path Stroke="{DynamicResource BorderBrush}"
                      StrokeThickness="1"
                      Data="M-60,438 C74,388 176,484 326,430 C470,378 544,294 696,334 C846,374 916,506 1086,446 C1168,416 1216,380 1266,390" />
            </Canvas>

            <Border x:Name="TitleBar"
                    Grid.Row="0"
                    Background="{DynamicResource TitleBarBrush}"
                    CornerRadius="16,16,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="26,0,0,0">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="AppNameText" Text="WinTab" FontSize="17" FontWeight="SemiBold" />
                            <TextBlock x:Name="AppTaglineText" Text="Explorer tab control" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,18,0" VerticalAlignment="Center">
                        <Button x:Name="ThemeToggleButton"
                                Style="{StaticResource IconButtonStyle}"
                                Width="32"
                                Height="32"
                                Margin="0,0,8,0"
                                Focusable="False">
                            <Viewbox Width="16" Height="16" Stretch="Uniform">
                                <Path x:Name="ThemeToggleIconPath"
                                      Fill="{DynamicResource TextPrimaryBrush}"
                                      Data="M10 7C10 10.866 13.134 14 17 14C18.9584 14 20.729 13.1957 21.9995 11.8995C22 11.933 22 11.9665 22 12C22 17.5228 17.5228 22 12 22C6.47715 22 2 17.5228 2 12C2 6.47715 6.47715 2 12 2C12.0335 2 12.067 2 12.1005 2.00049C10.8043 3.27098 10 5.04157 10 7ZM4 12C4 16.4183 7.58172 20 12 20C15.0583 20 17.7158 18.2839 19.062 15.7621C18.3945 15.9187 17.7035 16 17 16C12.0294 16 8 11.9706 8 7C8 6.29648 8.08133 5.60547 8.2379 4.938C5.71611 6.28423 4 8.9417 4 12Z" />
                            </Viewbox>
                        </Button>
                        <Button x:Name="LanguageToggleButton"
                                Style="{StaticResource IconButtonStyle}"
                                Width="32"
                                Height="32"
                                Margin="0,0,12,0"
                                Focusable="False">
                            <Viewbox Width="16" Height="16" Stretch="Uniform">
                                <Path Fill="{DynamicResource TextPrimaryBrush}"
                                      Data="M5 15V17C5 18.0544 5.81588 18.9182 6.85074 18.9945L7 19H10V21H7C4.79086 21 3 19.2091 3 17V15H5ZM18 10L22.4 21H20.245L19.044 18H14.954L13.755 21H11.601L16 10H18ZM17 12.8852L15.753 16H18.245L17 12.8852ZM8 2V4H12V11H8V14H6V11H2V4H6V2H8ZM17 3C19.2091 3 21 4.79086 21 7V9H19V7C19 5.89543 18.1046 5 17 5H14V3H17ZM6 6H4V9H6V6ZM10 6H8V9H10V6Z" />
                            </Viewbox>
                        </Button>
                        <Button x:Name="MinimizeButton" Style="{StaticResource IconButtonStyle}" Content="&#x2212;" Focusable="False" />
                        <Button x:Name="CloseButton" Style="{StaticResource IconButtonStyle}" Content="&#x2715;" Focusable="False" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="26,18,26,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="330" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource SoftPanelStyle}"
                        Padding="28">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <Image Source="/WinTab;component/wintab-logo.png"
                                   Width="116"
                                   Height="116"
                                   HorizontalAlignment="Left"
                                   Stretch="Uniform" />

                            <TextBlock x:Name="HeroTitleText"
                                       Text="File Explorer tab manager"
                                       Margin="0,20,0,0"
                                       FontSize="31"
                                       FontWeight="SemiBold"
                                       LineHeight="38"
                                       TextWrapping="Wrap" />
                            <TextBlock x:Name="HeroDescriptionText"
                                       Text="WinTab merges newly opened folders into existing Explorer windows and reuses tabs for paths that are already open."
                                       Margin="0,12,0,0"
                                       FontSize="13.5"
                                       LineHeight="22"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <Border Grid.Row="1"
                                Margin="0,24,0,0"
                                Padding="14,11"
                                Background="{DynamicResource StatusPillBackgroundBrush}"
                                BorderBrush="{DynamicResource StatusPillBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="22">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse Width="8" Height="8" Fill="{DynamicResource WarningBrush}" Margin="0,0,9,0" />
                                <TextBlock x:Name="StatusPillText"
                                           Text="Explorer tabs are being managed"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                            </StackPanel>
                        </Border>

                        <StackPanel Grid.Row="3">
                            <Border Padding="0,0,0,16"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="0,0,0,1"
                                    Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock x:Name="StatusTrayText" Text="Tray service running" Style="{StaticResource TinyMetaStyle}" />
                                    <TextBlock x:Name="StatusUpdateText" Text="Automatic updates enabled" Margin="0,7,0,0" Style="{StaticResource TinyMetaStyle}" />
                                    <TextBlock x:Name="StatusBypassText" Text="Ctrl + Shift temporarily bypasses merging" Margin="0,7,0,0" Style="{StaticResource TinyMetaStyle}" />
                                </StackPanel>
                            </Border>

                            <TextBlock x:Name="OpenSourceLicenseText"
                                       Text="Open source license: MIT License"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                            <TextBlock x:Name="OpenSourceVersionText"
                                       Margin="0,6,0,0"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                            <TextBlock Margin="0,8,0,0"
                                       FontSize="12"
                                       TextWrapping="Wrap">
                                <Hyperlink x:Name="OpenSourceLink"
                                           NavigateUri="https://github.com/OUBIGFA/WinTab"
                                           RequestNavigate="OpenSourceLink_RequestNavigate">
                                    <Run x:Name="OpenSourceLinkText" Text="https://github.com/OUBIGFA/WinTab" />
                                </Hyperlink>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Column="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="True">
                    <StackPanel>
                        <Border Style="{StaticResource PanelBorderStyle}">
                            <Grid>
                                <StackPanel>
                                    <Border Style="{StaticResource SettingRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock x:Name="WindowHookTitleText" Text="Auto-merge new Explorer windows" Style="{StaticResource SettingTitleStyle}" />
                                                <TextBlock x:Name="WindowHookDescText" Text="Move newly opened folders back into the main Explorer tab set." Style="{StaticResource SettingDescriptionStyle}" />
                                            </StackPanel>
                                            <CheckBox x:Name="WindowHookToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource CustomCheckBoxStyle}"
                                                      VerticalAlignment="Center"
                                                      Margin="22,0,0,0" />
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SettingRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock x:Name="ReuseTabsTitleText" Text="Reuse tabs" Style="{StaticResource SettingTitleStyle}" />
                                                <TextBlock x:Name="ReuseTabsDescText" Text="Focus an existing tab when the target path is already open." Style="{StaticResource SettingDescriptionStyle}" />
                                            </StackPanel>
                                            <CheckBox x:Name="ReuseTabsToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource CustomCheckBoxStyle}"
                                                      VerticalAlignment="Center"
                                                      Margin="22,0,0,0" />
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SettingRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock x:Name="DoubleClickTitleText" Text="Double-click to close tab" Style="{StaticResource SettingTitleStyle}" />
                                                <TextBlock x:Name="DoubleClickDescText" Text="Close the current Explorer tab from the tab title area." Style="{StaticResource SettingDescriptionStyle}" />
                                            </StackPanel>
                                            <CheckBox x:Name="DoubleClickCloseToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource CustomCheckBoxStyle}"
                                                      VerticalAlignment="Center"
                                                      Margin="22,0,0,0" />
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SettingRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock x:Name="StartupTitleText" Text="Start with Windows" Style="{StaticResource SettingTitleStyle}" />
                                                <TextBlock x:Name="StartupDescText" Text="Keep the utility available after sign-in without opening this panel." Style="{StaticResource SettingDescriptionStyle}" />
                                            </StackPanel>
                                            <CheckBox x:Name="StartupToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource CustomCheckBoxStyle}"
                                                      VerticalAlignment="Center"
                                                      Margin="22,0,0,0" />
                                        </Grid>
                                    </Border>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock x:Name="AutoUpdateTitleText" Text="Automatic updates" Style="{StaticResource SettingTitleStyle}" />
                                            <TextBlock x:Name="AutoUpdateDescText" Text="Check GitHub releases so fixes are offered without manual polling." Style="{StaticResource SettingDescriptionStyle}" />
                                        </StackPanel>
                                        <CheckBox x:Name="AutoUpdateToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource CustomCheckBoxStyle}"
                                                  VerticalAlignment="Center"
                                                  Margin="22,0,0,0" />
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource SoftPanelStyle}" Margin="0,16,0,0" Padding="24,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock x:Name="ActionsTitleText" Text="Actions" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock x:Name="ActionsDescText"
                                               Text="Open from tray anytime. Closing this window keeps WinTab running."
                                               Style="{StaticResource SectionDescriptionStyle}"
                                               Margin="0,7,0,0" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="24,0,0,0">
                                    <Button x:Name="CheckUpdatesButton"
                                            Content="Check Updates"
                                            Style="{StaticResource FlatButtonStyle}"
                                            MinWidth="100"
                                            Margin="0,0,10,0" />
                                    <Button x:Name="HideWindowButton"
                                            Content="Hide to Tray"
                                            Style="{StaticResource FlatButtonStyle}"
                                            MinWidth="104" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <Border Grid.Row="2"
                    Background="{DynamicResource FooterBrush}"
                    CornerRadius="0,0,16,16"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0">
                <Grid Margin="26,0">
                    <TextBlock x:Name="FooterTipText"
                               Text="Ctrl + Shift while opening a folder keeps that open as a separate Explorer window."
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="13"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center" />
                    <Thumb x:Name="CornerResizeThumb"
                           Width="20"
                           Height="20"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Bottom"
                           Margin="0,0,2,2"
                           Cursor="SizeNWSE"
                           Opacity="0.65"
                           ToolTip="Resize">
                        <Thumb.Template>
                            <ControlTemplate TargetType="Thumb">
                                <Grid Background="Transparent">
                                    <Path Stroke="{DynamicResource TextTertiaryBrush}"
                                          StrokeThickness="1.3"
                                          Data="M7,16 L16,7 M11,16 L16,11 M3,16 L16,3" />
                                </Grid>
                            </ControlTemplate>
                        </Thumb.Template>
                    </Thumb>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
