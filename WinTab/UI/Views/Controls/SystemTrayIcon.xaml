<UserControl x:Class="WinTab.UI.Views.Controls.SystemTrayIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tb="http://www.hardcodet.net/taskbar">

    <tb:TaskbarIcon x:Name="TrayIcon"
                    Visibility="Visible"
                    TrayMouseDoubleClick="OnNotifyIconDoubleClick">
        <tb:TaskbarIcon.ContextMenu>
            <ContextMenu>
                <MenuItem x:Name="OpenSettingsMenu" Header="Open WinTab" />
                <Separator />
                <MenuItem x:Name="WindowHookMenu" Header="Auto-merge Explorer windows" IsCheckable="True" StaysOpenOnClick="True" />
                <MenuItem x:Name="ReuseTabsMenu" Header="Reuse tabs" IsCheckable="True" StaysOpenOnClick="True" />
                <MenuItem x:Name="DoubleClickCloseMenu" Header="Double-click to close tab" IsCheckable="True" StaysOpenOnClick="True" />
                <Separator />
                <MenuItem x:Name="StartupMenu" Header="Start with Windows" IsCheckable="True" StaysOpenOnClick="True" />
                <MenuItem x:Name="AutoUpdateMenu" Header="Automatic updates" IsCheckable="True" StaysOpenOnClick="True" />
                <MenuItem x:Name="ShowTrayIconMenu" Header="Show tray icon" IsCheckable="True" StaysOpenOnClick="True" />
                <Separator />
                <MenuItem x:Name="CheckUpdatesMenu" Header="Check for updates" />
                <MenuItem x:Name="ExitMenu" Header="Exit" />
            </ContextMenu>
        </tb:TaskbarIcon.ContextMenu>
    </tb:TaskbarIcon>

</UserControl>
